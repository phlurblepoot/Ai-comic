{
  "10": {
    "class_type": "UNETLoader",
    "inputs": {"unet_name": "{{CHECKPOINT}}", "weight_dtype": "fp8_e4m3fn"}
  },
  "11": {
    "class_type": "DualCLIPLoader",
    "inputs": {"clip_name1": "{{T5}}", "clip_name2": "{{CLIP_L}}", "type": "flux"}
  },
  "12": {
    "class_type": "VAELoader",
    "inputs": {"vae_name": "{{VAE}}"}
  },
  "30": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["11", 0],
      "text": "{{POSITIVE_PROMPT}}, establishing shot, no people, detailed environment, consistent architecture and lighting"
    }
  },
  "31": {
    "class_type": "CLIPTextEncode",
    "inputs": {"clip": ["11", 0], "text": "people, characters, person, human figure"}
  },
  "40": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {"width": "{{WIDTH}}", "height": "{{HEIGHT}}", "batch_size": 1}
  },
  "50": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["10", 0],
      "positive": ["30", 0],
      "negative": ["31", 0],
      "latent_image": ["40", 0],
      "seed": "{{SEED}}",
      "steps": 28,
      "cfg": 3.5,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0
    }
  },
  "60": {
    "class_type": "VAEDecode",
    "inputs": {"samples": ["50", 0], "vae": ["12", 0]}
  },
  "70": {
    "class_type": "SaveImage",
    "inputs": {"images": ["60", 0], "filename_prefix": "{{OUTPUT_PREFIX}}"}
  },
  "80": {
    "class_type": "DepthAnythingV2Preprocessor",
    "inputs": {"image": ["60", 0], "ckpt_name": "depth_anything_v2_vitl.pth", "resolution": 1024}
  },
  "81": {
    "class_type": "SaveImage",
    "inputs": {"images": ["80", 0], "filename_prefix": "{{OUTPUT_PREFIX}}_depth"}
  }
}
