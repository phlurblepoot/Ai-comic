{
  "10": {
    "class_type": "UNETLoader",
    "inputs": {"unet_name": "{{KONTEXT_MODEL}}", "weight_dtype": "fp8_e4m3fn"}
  },
  "11": {
    "class_type": "DualCLIPLoader",
    "inputs": {"clip_name1": "{{T5}}", "clip_name2": "{{CLIP_L}}", "type": "flux"}
  },
  "12": {
    "class_type": "VAELoader",
    "inputs": {"vae_name": "{{VAE}}"}
  },
  "20": {
    "class_type": "LoadImage",
    "inputs": {"image": "{{CHARACTER_IMAGE}}"}
  },
  "21": {
    "class_type": "LoadImage",
    "inputs": {"image": "{{OUTFIT_IMAGE}}"}
  },
  "22": {
    "class_type": "ImageStitch",
    "inputs": {
      "image1": ["20", 0],
      "image2": ["21", 0],
      "direction": "right",
      "match_image_size": true,
      "spacing_width": 0,
      "spacing_color": "white"
    }
  },
  "23": {
    "class_type": "FluxKontextImageScale",
    "inputs": {"image": ["22", 0]}
  },
  "24": {
    "class_type": "VAEEncode",
    "inputs": {"pixels": ["23", 0], "vae": ["12", 0]}
  },
  "30": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["11", 0],
      "text": "Keep the character on the left exactly the same (face, hair, proportions). Dress them in the outfit shown on the right. {{POSITIVE_PROMPT}}"
    }
  },
  "31": {
    "class_type": "CLIPTextEncode",
    "inputs": {"clip": ["11", 0], "text": ""}
  },
  "32": {
    "class_type": "ReferenceLatent",
    "inputs": {"conditioning": ["30", 0], "latent": ["24", 0]}
  },
  "40": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["10", 0],
      "positive": ["32", 0],
      "negative": ["31", 0],
      "latent_image": ["24", 0],
      "seed": "{{SEED}}",
      "steps": 28,
      "cfg": 2.5,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0
    }
  },
  "50": {
    "class_type": "VAEDecode",
    "inputs": {"samples": ["40", 0], "vae": ["12", 0]}
  },
  "60": {
    "class_type": "SaveImage",
    "inputs": {"images": ["50", 0], "filename_prefix": "{{OUTPUT_PREFIX}}"}
  }
}
