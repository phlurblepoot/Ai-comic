# Copy this file to .env and edit before running locally.
# docker compose will pick it up automatically.

# Required: URL of your ComfyUI instance.
AICOMIC_COMFY_URL=http://10.0.0.5:8188

# Optional: Bearer token if ComfyUI is behind an authenticated reverse proxy.
AICOMIC_COMFY_TOKEN=

# Port the UI listens on (also change the port mapping if you change this).
AICOMIC_BIND_PORT=7860
